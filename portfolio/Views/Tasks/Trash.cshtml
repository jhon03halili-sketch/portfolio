@{
    ViewData["Title"] = "Trash";
    ViewData["HideBackButton"] = true; // 🔥 hide it here
}
@{
    Layout = "~/Views/Shared/_TaskLayout.cshtml";
}
@model IEnumerable<portfolio.Models.TaskItem>

@{
    ViewData["Title"] = "Trash";
}

<div class="task-shell">
    <div class="task-top-bar">
        <h1 class="task-page-title">Trash</h1>

        <p class="task-add-wrap">
            <a asp-action="Index" class="btn-toggle" style="text-decoration:none;">← Back to Tasks</a>
        </p>
    </div>

    <div class="task-table-wrap">
        <table class="table table-dark table-striped table-bordered align-middle task-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th class="actions-heading">Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Any())
                {
                    @foreach (var task in Model)
                    {
                        <tr>
                            <td data-label="Title">@task.Title</td>
                            <td data-label="Description">@task.Description</td>
                            <td data-label="Due Date">@task.DueDate.ToShortDateString()</td>

                            <td data-label="Status">
                                @if (task.IsCompleted)
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                            </td>

                            <td data-label="Actions" class="actions-cell">
                                <div class="action-buttons">
                                    <form asp-action="Restore" asp-route-id="@task.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-edit">Restore</button>
                                    </form>

                                    <form asp-action="PermanentDelete" asp-route-id="@task.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-delete">Delete Permanently</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center">Trash is empty.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>