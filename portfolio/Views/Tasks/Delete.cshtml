@{
    Layout = "~/Views/Shared/_TaskLayout.cshtml";
}
@model portfolio.Models.TaskItem

@{
    ViewData["Title"] = "Delete Task";
}

<div class="container text-white task-page">
    <h1 class="mb-4">Delete Task</h1>

    <div class="alert alert-warning">
        Are you sure you want to delete this task?
    </div>

    <div class="mb-3">
        <strong>Title:</strong> @Model.Title
    </div>

    <div class="mb-3">
        <strong>Description:</strong> @Model.Description
    </div>

    <div class="mb-3">
        <strong>Due Date:</strong> @Model.DueDate.ToShortDateString()
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>