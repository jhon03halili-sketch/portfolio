@{
    ViewData["Title"] = "Home";
}

<section id="home" class="hero-section home-bg">
    <div class="bw-gradient"></div>
    <div class="bw-vignette"></div>
    <div class="bw-noise"></div>

    <div class="hero-content center-hero">
        <h1>Jhon Carlo Halili</h1>

        <div class="hero-roles">
            <span class="role-item">Student</span>
            <span class="role-item">Graphic Designer</span>
            <span class="role-item">Digital Marketing VA</span>
        </div>
    </div>
</section>

<section id="about" class="about-section">
    <div class="about-container">

        <!-- LEFT SIDE (TEXT) -->
        <div class="about-text">
            <h2>About Me</h2>

            <p>
                I’m Jhon Carlo Halili, a student and aspiring developer with a strong
                foundation in graphic design and digital marketing. I enjoy creating
                clean, modern, and user-focused digital experiences.
            </p>

            <p>
                With experience in content creation, branding, and web development,
                I combine creativity and strategy to build meaningful and impactful work.
            </p>
        </div>

        <!-- RIGHT SIDE (IMAGE PLACEHOLDER) -->
        <div class="about-image">
            <div class="image-placeholder">
                Your Photo Here
            </div>
        </div>

    </div>
</section>

