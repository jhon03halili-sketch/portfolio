@{
    Layout = "~/Views/Shared/_TaskLayout.cshtml";
}
@model IEnumerable<portfolio.Models.TaskItem>

@{
    ViewData["Title"] = "Task Manager";
}

<div class="task-shell">
    <h1 class="task-page-title">Task Manager App</h1>

    <p class="task-add-wrap">
        <a asp-action="Create" class="btn btn-info task-add-btn">+ Add New Task</a>
    </p>

    <div class="task-table-wrap">
        <table class="table table-dark table-striped table-bordered align-middle task-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th class="actions-heading">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var task in Model)
                {
                    <tr>
                        <td data-label="Title">@task.Title</td>
                        <td data-label="Description">@task.Description</td>
                        <td data-label="Due Date">@task.DueDate.ToShortDateString()</td>

                        <td data-label="Status">
                            @if (task.IsCompleted)
                            {
                                <span class="badge bg-success">Completed</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                        </td>

                        <td data-label="Actions" class="actions-cell">
                            <div class="action-buttons">
                                <div class="action-row">
                                    <a asp-action="Edit" asp-route-id="@task.Id" class="btn-edit">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@task.Id" class="btn-delete">Delete</a>
                                </div>

                                <form asp-action="ToggleComplete" asp-route-id="@task.Id" method="post">
                                    <button type="submit" class="btn-toggle">
                                        @(task.IsCompleted ? "Mark Pending" : "Mark Complete")
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>